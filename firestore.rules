rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, role, createdAt
    //
    // Collection: plans
    // Fields: name, price, description, imageUrl, createdAt
    //
    // Collection: orders
    // Fields: userId, planId, planName, price, status, utrId, screenshotUrl, giftCode, createdAt, updatedAt, adminNote
    //
    // Collection: settings
    // Fields: qrCodeUrl, upiId
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email in ["Mr.bitu9t9@gmail.com", "ribankumari533@gmail.com"]);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isOrderOwner(orderData) {
      return isAuthenticated() && request.auth.uid == orderData.userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Users
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                    hasOnlyAllowedFields(['uid', 'email', 'role', 'createdAt']) &&
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin();
    }

    // Plans
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid &&
                    (request.resource.data.status == 'pending' || request.resource.data.status == 'completed');
      allow update: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
